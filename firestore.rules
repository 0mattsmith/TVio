rules_version = '2';

// TVio Firestore security rules.
//
// NOT deployed by CI — paste these into the Firebase Console (Firestore
// Database → Rules → Publish), or run `firebase deploy --only firestore:rules`.
// They live here so the rules are reviewable alongside the code that relies on
// them; the console is the source of truth for what's actually enforced.
//
// Note the Cloudflare Worker talks to Firestore with a service account, which
// bypasses these rules completely. That's deliberate: redeeming a pairing code
// has to be done by something the client can't impersonate.

service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own synced state: profiles, watchlist, progress, sources, keys.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Short-lived QR sign-in codes.
    //
    // The code IS the secret, so a document is only ever readable by the device
    // that created it. The phone never touches this collection — it POSTs the
    // code to the Worker, which verifies expiry, enforces single use, and mints
    // the custom token.
    match /pairings/{code} {
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.redeemed == false
                    && request.resource.data.expiresAt is number
                    // Loose sanity bound only — tolerates client clock skew,
                    // while the Worker enforces the real 3-minute expiry.
                    && request.resource.data.expiresAt <= request.time.toMillis() + 3600000;

      // The creating desktop polls for redemption and can cancel its own code.
      allow get, delete: if request.auth != null
                         && resource.data.ownerUid == request.auth.uid;

      // Only the Worker may flip `redeemed` — a client that could do this
      // could hand itself a session for someone else's account.
      allow update: if false;

      allow list: if false;
    }

    // TV sign-in codes. Written and read exclusively by the Worker's service
    // account (which bypasses these rules), because the TV has no account yet
    // and the phone proves itself with an ID token instead. No client should
    // ever touch this collection directly.
    match /devicePairings/{code} {
      allow read, write: if false;
    }

    // Anything not matched above is denied.
  }
}
