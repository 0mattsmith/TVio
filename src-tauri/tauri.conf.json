{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TVio",
  "version": "0.1.0",
  "identifier": "app.tvio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TVio",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "TVio",
    "copyright": "© TVio",
    "category": "Entertainment",
    "shortDescription": "Films, series & live TV — your way",
    "longDescription": "TVio brings your streaming services, your own sources and Live TV together in one clean, Netflix-style interface.",
    "homepage": "https://github.com/0mattsmith/TVio",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "compression": "lzma"
      },
      "wix": {
        "bannerPath": "installer/banner.bmp",
        "dialogImagePath": "installer/dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/0mattsmith/TVio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxRTczRDc3NzVEMzZGMjUKUldRbGI5TjFkejNuZ1ptTkZtM3F4d0oxWHVNTVllNFo4T3R2aUdFbWVSby9YZDhwR01Hck1RcDgK",
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
