# Copy this file to .env.local and fill in your keys. .env.local is git-ignored.

# --- TMDB (required) --- get a free key at https://www.themoviedb.org/settings/api
VITE_TMDB_KEY=your_tmdb_api_key_here
# Optional: TMDB v4 read access token (Bearer). If set, used instead of the v3 key.
VITE_TMDB_TOKEN=
# Region drives "where to watch" providers (ISO 3166-1). e.g. US, GB, AU
VITE_TMDB_REGION=GB

# --- Optional: TMDB proxy (recommended for public builds) ---
# A tiny serverless endpoint (e.g. Cloudflare Worker) that holds the key
# server-side, so it never ships in the client bundle and users need zero setup.
# When set, VITE_TMDB_KEY is not sent from the browser at all.
# e.g. https://tvio-api.yourname.workers.dev/tmdb
VITE_TMDB_PROXY=

# --- OMDb (optional, IMDb/RT ratings enrichment) --- http://www.omdbapi.com/apikey.aspx
VITE_OMDB_KEY=

# --- Firebase (optional now; required for real auth/sync) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
